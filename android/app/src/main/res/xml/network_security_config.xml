<?xml version="1.0" encoding="utf-8"?>
<!--
  RELEASE ağ güvenlik yapılandırması (§10.3.2, §10.4.2).

  - Cleartext (HTTP) trafiği TAMAMEN kapalı — istisna yok.
  - Yalnızca SİSTEM CA'larına güvenilir. Kullanıcının cihaza eklediği
    sertifikalara (Burp/mitmproxy vb. MITM proxy CA'ları) release'te
    GÜVENİLMEZ; bu, API trafiğinin araya girilerek okunmasını engeller.
  - Geliştirme istisnaları (emülatör host'u, LAN IP, user CA) debug
    source set'teki kopyada: android/app/src/debug/res/xml/
    network_security_config.xml — release paketine girmez.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- debug-overrides yalnızca android:debuggable=true iken etkindir;
         release build'lerde tamamen yok sayılır. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
