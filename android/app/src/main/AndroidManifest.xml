<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Internet izni - Google Maps için gerekli -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Konum izinleri - Harita ve Geofencing için -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- BACKGROUND LOCATION: Geofencing için ZORUNLU -->
    <!-- Kullanıcı cebinde telefonla yürürken "Kavak'a hoş geldiniz" gibi -->
    <!-- bildirimler alabilmesi için arka plan konum izni gereklidir. -->
    <!-- Android 10+ (API 29+) için gereklillik: Google Play Store, bu izni -->
    <!-- istemek için uygulamanızın neden ihtiyaç duyduğunu açıklayan bir -->
    <!-- form doldurmanızı ister. Açıklama: "Kullanıcılara yakınlarındaki -->
    <!-- turistik yerler hakkında otomatik bildirim göndermek için." -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    
    <!-- Push Notifications: Android 13+ (API 33+) için bildirim izni -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Camera: QR code scanning (mobile_scanner) ve AR için -->
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- Native geofencing (GeofencingClient): reboot/paket güncelleme sonrası
         OS geofence'leri silinir → boot receiver ile yeniden kaydedilir. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- NOT: FOREGROUND_SERVICE KULLANILMIYOR — geofencing event-tabanlı
         (OS uygulamayı bölgeye girince uyandırır), polling/foreground service yok. -->
    
    <application
        android:label="sbb_mobile"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:largeHeap="true"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Impeller (Vulkan) kapatıldı: mobile_scanner kamera preview'i bazı
             cihazlarda Impeller ile periyodik donuyordu. AR (SceneView/Filament)
             kendi render motorunu kullandığı için etkilenmez; ana UI Skia'ya
             düşer. Sorun çözülürse bu kaldırılabilir. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
        <!-- Google Maps API key: injected at build time from android/local.properties (MAPS_API_KEY) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />
        
        <!-- NOT: BackgroundService KALDIRILDI -->
        <!-- GEOFENCE_MASTER.md'ye göre background service kullanılmıyor. -->

        <!-- ARCore: Scene Viewer ile kamera üzerinden 3D/AR görüntüleme -->
        <!-- "optional" = ARCore desteklemeyen cihazlarda da uygulama çalışır -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <!-- Native geofencing: ENTER tetiklemesini alan receiver (OS uyandırır). -->
        <receiver
            android:name=".GeofenceBroadcastReceiver"
            android:exported="false" />

        <!-- Reboot / paket güncellemesi sonrası geofence'leri yeniden kaydet. -->
        <receiver
            android:name=".GeofenceBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>
    <!-- Tek <queries> bloğu: Android 11+ paket görünürlük kuralları -->
    <queries>
        <!-- AR: Google Scene Viewer intent'i (model_viewer_plus AR modu) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <!-- AR: Scene Viewer için package query -->
        <package android:name="com.google.android.googlequicksearchbox" />
        <!-- Flutter: text processing -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- URL launcher: HTTP/HTTPS intent'leri -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>
</manifest>
