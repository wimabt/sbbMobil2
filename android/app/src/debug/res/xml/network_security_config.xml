<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG ağ güvenlik yapılandırması.

  Kaynak birleştirme (resource merging) kuralı gereği debug build'lerde bu
  dosya, main/res/xml/network_security_config.xml'in YERİNE geçer.
  Release paketine ASLA girmez — geliştirme kolaylıkları burada kalabilir.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <!-- Debug'da MITM proxy (Burp/mitmproxy) ile trafik incelemeye
                 izin ver: kullanıcı CA'larına güven. -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Emülatör host'u ve geliştirici makinesi LAN IP'si: yerel backend'e
         HTTP ile bağlanabilmek için (yalnızca debug). -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.137.1</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
