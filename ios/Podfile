# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

      # permission_handler: uygulamada kullanılan TÜM izinleri native tarafta
      # aktif etmek için gerekli (Android'deki AndroidManifest.xml karşılığı).
      # Makro eksik olan izin türünde permission_handler'ın iOS native kodu
      # o strateji dosyasını hiç DERLEMEZ; sonuç: sistem izin penceresi HİÇ
      # açılmaz, `request()` sessizce `denied` döner (cila.md #1'deki kamera
      # izni bug'ının kök sebebi buydu). Bu yüzden kullanılan HER izin burada
      # eksiksiz listelenmeli — yeni bir izin eklenince buraya da eklenmeli.
      #
      # Kullanılan izinler (kod taraması, 7 Temmuz 2026):
      #   • Kamera            → ar_readiness_gate.dart, ar_capability_service.dart,
      #                          third_party/ar_flutter_plugin_2 (AR/QR tarayıcı)
      #   • Konum (ön plan)   → home_screen.dart, location_service.dart (Geolocator
      #                          üzerinden gider, permission_handler'a ihtiyaç
      #                          duymaz ama PERMISSION_LOCATION taban makrosu
      #                          "her zaman" akışının da içinde bulunduğu
      #                          LocationPermissionStrategy.m'yi derlemek için şart)
      #   • Konum (her zaman) → geofence_service.dart (`Permission.locationAlways`,
      #                          bölge bildirimleri arka planda çalışsın diye)
      #   • Bildirim          → OneSignal SDK kendi native izni kullanıyor
      #                          (permission_handler'a bağımlı DEĞİL), makro
      #                          zararsız — ileride başka bir plugin ihtiyaç
      #                          duyarsa diye bırakıldı.
      #
      # Mevcut değer String de olabilir Array de — ikisini de güvenle işle.
      existing_defs = Array(config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || '$(inherited)')
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = existing_defs + [
        'PERMISSION_CAMERA=1',
        'PERMISSION_LOCATION=1',
        'PERMISSION_LOCATION_WHENINUSE=1',
        'PERMISSION_LOCATION_ALWAYS=1',
        'PERMISSION_NOTIFICATIONS=1',
      ]
    end
  end
end
